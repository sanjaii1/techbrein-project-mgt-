# Root .gitignore to manage both backend and frontend

# Node.js dependencies
**/node_modules/

# Next.js build output
**/ .next/
**/out/

# Build artifacts
**/dist/
**/build/

# Testing
**/coverage/

# Logs
**/*.log*
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*

# Environment files
**/.env*

# OS artifacts
.DS_Store
Thumbs.db

# IDE settings
.vscode/
.idea/

# Local build artifacts
**/*.tsbuildinfo
next-env.d.ts
